        "useDefaultSymbol" : true,
        "isDefaultSymbolVisible" : true,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var json = Dictionary($feature.attributebindings)\nvar buoyShape = IIf(HasKey(json, \"buoyShape\"),json[\"buoyShape\"],-1)\nvar colour0 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\nvar colour1 = IIf(HasKey(json, \"colour[1]\"),json[\"colour[1]\"],-1)\nvar colour2 = IIf(HasKey(json, \"colour[2]\"),json[\"colour[2]\"],-1)\n\n// Check for Black, Red, Black pattern: colour[0]==2, colour[1]==3, colour[2]==2 in Arcade zero-based indexing\n// In Arcade, arrays are zero-based, so colour[0] is the first element\n\n// Check if colour exists and has at least 3 elements\nif (colour0 == 2 && colour1 == 3 && colour2 == 2) {\n    \n    if (buoyShape == 4) {\n        return \"BOYPIL40\"\n    } else if (buoyShape == 5) {\n        return \"BOYSPR40\"\n    }\n}\nelse if (buoyShape == 1) {\n    return \"BOYCON01\"\n} else if (buoyShape == 2) {\n    return \"BOYCAN01\"\n} else if (buoyShape == 3) {\n    return \"BOYSPH01\"\n} else if (buoyShape == 4) {\n    return \"BOYPIL01\"\n} else if (buoyShape == 5) {\n    return \"BOYSPR01\"\n} else if (buoyShape == 6) {\n    return \"BOYBAR01\"\n} else if (buoyShape == 7) {\n    return \"BOYSUP01\"\n} else if (buoyShape == 8) {\n    return \"BOYSPR01\"\n} else {\n    return \"BOYGEN03\"\n}",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
      "scaleSymbols" : true,
      "snappable" : true
    },
