          "workspaceConnectionString" : "SERVER=ncps-sql101041.prod.sitad.dk;INSTANCE=sde:sqlserver:ncps-sql101041.prod.sitad.dk;DBCLIENT=sqlserver;DB_CONNECTION_PROPERTIES=ncps-sql101041.prod.sitad.dk;DATABASE=s100edx_sapphire;VERSION=sde.DEFAULT;AUTHENTICATION_MODE=OSA",
