      "htmlPopupEnabled" : true,
      "selectable" : true,
      "featureCacheType" : "Session",
      "displayFiltersType" : "ByScale",
      "featureBlendingMode" : "Alpha",
      "layerEffectsMode" : "Layer",
      "labelClasses" : [
        {
          "type" : "CIMLabelClass",
          "expressionTitle" : "Custom",
          "expression" : "function IsNumeric(val) {\n    return !(IsEmpty(Number(val)) || Number(val) == null);\n}\n\nvar json = Dictionary($feature.attributebindings)\n\nvar c1 = IIf(HasKey(json, \"sectorCharacteristics[0].lightSector[0].colour[0]\"),json[\"sectorCharacteristics[0].lightSector[0].colour[0]\"],-1)\nvar COLOUR = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1) + \"\"\nvar LITCHR = IIf(HasKey(json, \"rhythmOfLight.lightCharacteristic\"),json[\"rhythmOfLight.lightCharacteristic\"],-1)\n\nvar countSignalGroups = 0;\nvar i = 0;\nvar SIGGRP = \"\"\n\nwhile (HasKey(json, \"rhythmOfLight.signalGroup[\" + i + \"]\")) {\n    countSignalGroups += 1;\n    SIGGRP += json[\"rhythmOfLight.signalGroup[\" + i + \"]\"]\n    i += 1;\n}\n\n\n\nvar CATLIT = IIf(HasKey(json, \"categoryOfLight[0]\"),json[\"categoryOfLight[0]\"],-1) + \"\"\nvar SIGPER = IIf(HasKey(json, \"rhythmOfLight.signalPeriod\"),json[\"rhythmOfLight.signalPeriod\"],-1)\nvar HEIGHT = IIf(HasKey(json, \"height\"),json[\"height\"],-1)\nvar VALNMR = IIf(HasKey(json, \"valueOfNominalRange\"),json[\"valueOfNominalRange\"],-1)\nvar MLTYLT = \"\";\n\n// category of light\nvar strCATLIT = \"\";\nif (CATLIT == \"5\") {\n    strCATLIT = \"AERO  \";\n} else if (CATLIT == \"7\") {\n    strCATLIT = \"Fog Det Lt\";\n} else if (IsEmpty(CATLIT)) {\n    strCATLIT = \"\";\n} else {\n    strCATLIT = \"\";\n}\n\n// light characteristics\nvar strLITCHR = \"\";\nif (LITCHR == 1 || LITCHR == \"fixed\") {\n    strLITCHR = \"F\";\n} else if (LITCHR == 2 || LITCHR == \"flashing\") {\n    strLITCHR = \"Fl\";\n} else if (LITCHR == 3 || LITCHR == \"long-flashing\") {\n    strLITCHR = \"LFl\";\n} else if (LITCHR == 4 || LITCHR == \"quick-flashing\") {\n    strLITCHR = \"Q\";\n} else if (LITCHR == 5 || LITCHR == \"very quick-flashing\") {\n    strLITCHR = \"VQ\";\n} else if (LITCHR == 6 || LITCHR == \"continuous ultra quick-flashing\") {\n    strLITCHR = \"UQ\";\n} else if (LITCHR == 7 || LITCHR == \"isophased\") {\n    strLITCHR = \"Iso\";\n} else if (LITCHR == 8 || LITCHR == \"occulting\") {\n    strLITCHR = \"Oc\";\n} else if (LITCHR == 11 || LITCHR == \"interrupted ultra quick-flashing\") {\n    strLITCHR = \"IQ\";\n} else if (LITCHR == 12 || LITCHR == \"morse\") {\n    strLITCHR = \"Mo\";\n} else if (LITCHR == 13 || LITCHR == \"fixed/flash\") {\n    strLITCHR = \"FFI\";\n} else if (LITCHR == 14 || LITCHR == \"flash/long-flash\") {\n    strLITCHR = \"LFI\";\n} else if (LITCHR == 15 || LITCHR == \"occulting/flash\") {\n    strLITCHR = \"OcFl\";\n} else if (LITCHR == 16 || LITCHR == \"fixed/long-flash\") {\n    strLITCHR = \"FLFI\";\n} else if (LITCHR == 17 || LITCHR == \"occulting alternating\") {\n    strLITCHR = \"OcAI.WR\";\n} else if (LITCHR == 18 || LITCHR == \"long-flash alternating\") {\n    strLITCHR = \"LFIAI.WR\";\n} else if (LITCHR == 19 || LITCHR == \"flash alternating\") {\n    strLITCHR = \"FLAI.WR\";\n} else if (LITCHR == \"group alternating\") {\n    strLITCHR = \"AI.WR\";\n} else if (LITCHR == 25 || LITCHR == \"quick-flash plus long-flash\") {\n    strLITCHR = \"LQ\";\n} else if (LITCHR == 26 || LITCHR == \"very quick-flash plus long-flash\") {\n    strLITCHR = \"LVQ\";\n} else if (LITCHR == 27 || LITCHR == \"ultra quick-flash plus long-flash\") {\n    strLITCHR = \"LUQ\";\n} else if (LITCHR == 28 || LITCHR == \"alternating\") {\n    strLITCHR = \"AI.WR\";\n} else if (LITCHR == 29 || LITCHR == \"fixed and alternating flashing\") {\n    strLITCHR = \"FAL.WR\";\n} else if (IsEmpty(LITCHR)) {\n    strLITCHR = \"\";\n} else {\n    strLITCHR = \"\";\n}\n\n// signal group\nvar strSIGGRP = \".\";\n\n//if (!IsEmpty(SIGGRP) && SIGGRP > \"(0)\") {\nif (!IsEmpty(SIGGRP) && SIGGRP != \"()\") {\n    strSIGGRP = SIGGRP;\n}\n\n// colour\nvar strCOLOUR = \"\";\nif (COLOUR == \"white\") {\n    strCOLOUR = \"\";\n} else if (COLOUR == \"2\") {\n    strCOLOUR = \"Bl\";\n} else if (COLOUR == \"3\") {\n    strCOLOUR = \"R\";\n} else if (COLOUR == \"4\") {\n    strCOLOUR = \"G\";\n} else if (COLOUR == \"5\") {\n    strCOLOUR = \"Bu\";\n} else if (COLOUR == \"6\") {\n    strCOLOUR = \"Y\";\n} else if (COLOUR == \"7\") {\n    strCOLOUR = \"Gr\";\n} else if (COLOUR == \"8\") {\n    strCOLOUR = \"Br\";\n} else if (COLOUR == \"9\") {\n    strCOLOUR = \"Am\";\n} else if (COLOUR == \"10\") {\n    strCOLOUR = \"Vi\";\n} else if (COLOUR == \"11\") {\n    strCOLOUR = \"Or\";\n} else if (COLOUR == \"12\") {\n    strCOLOUR = \"Ma\";\n} else if (COLOUR == \"13\") {\n    strCOLOUR = \"Pi\";\n} else if (IsEmpty(COLOUR)) {\n    strCOLOUR = \"\";\n    strSIGGRP = \"\";\n} else {\n    strCOLOUR = \"\";\n    strSIGGRP = \"\";\n}\nif (strCOLOUR != \"\") {\n    strCOLOUR += \".\";\n}\n\n// signal period\nvar strSIGPER = \"\";\nif (IsNumeric(SIGPER) && SIGPER > 0) {\n    // Replace '.' with ',' for decimals in Arcade\n    strSIGPER = Text(SIGPER, \"#.##\");\n    strSIGPER = Replace(strSIGPER, \".\", \",\") + \"s\";\n} else {\n    strSIGPER = \"\";\n}\n\n// height\nvar strHEIGHT = \"\";\nif (IsNumeric(HEIGHT) && HEIGHT > 0) {\n    strHEIGHT = Text(HEIGHT, \"#.#\") + \"m\";\n} else {\n    strHEIGHT = \"\";\n}\n\n// value of nominal range\nvar strVALNMR = \"\";\nif (IsNumeric(VALNMR) && VALNMR > 1) {\n    strVALNMR = Text(VALNMR, \"#\") + \"M\";\n} else {\n    strVALNMR = \"\";\n}\n\n// Compose final label string\nvar strLight = MLTYLT + strCATLIT + strLITCHR + strSIGGRP + strCOLOUR + strSIGPER + strHEIGHT + strVALNMR;\n\nreturn strLight;\n\n\n\n\n\n\n",
          "expressionEngine" : "Arcade",
          "featuresToLabel" : "AllVisibleFeatures",
