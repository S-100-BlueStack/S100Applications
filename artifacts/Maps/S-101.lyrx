          "expression" : "var json = Dictionary($feature.attributebindings)\nvar buoyShape = IIf(HasKey(json, \"buoyShape\"),json[\"buoyShape\"],-1)\n\nif (buoyShape == 1) {\nreturn \"BOYCON01\"\n}\nif (buoyShape == 2) {\nreturn \"BOYCAN01\"\n}\nif (buoyShape == 3) {\nreturn \"BOYSPH01\"\n}\nif (buoyShape == 4) {\nreturn \"BOYPIL01\"\n}\nif (buoyShape == 5) {\nreturn \"BOYSPR01\"\n}\nif (buoyShape == 6) {\nreturn \"BOYBAR01\"\n}\nif (buoyShape == 7) {\nreturn \"BOYSUP01\"\n}\nif (buoyShape == 8) {\nreturn \"BOYSPR01\"\n}\n\nreturn -1\n\n\n",
