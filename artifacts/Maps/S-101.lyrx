          "expression" : "var result = \"\"\nvar json = Dictionary($feature.attributebindings)\nvar buoyShape = IIf(HasKey(json,\"buoyShape\"),json[\"buoyShape\"],-1)\nvar colour0 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\nvar categoryOfSpecialPurposeMark = IIf(HasKey(json, \"categoryOfSpecialPurposeMark\"),json[\"categoryOfSpecialPurposeMark\"],[])\n\n\nif (buoyShape == 1 && colour0 == 6) {\n    result = \"BOYCON12\"\n} else if (buoyShape == 2 && colour0 == 6) {\n    result = \"BOYCAN12\"\n} else if (buoyShape == 3 && colour0 == 6) {\n    result = \"BOYSPH12\"\n} else if (buoyShape == 4 && colour0 == 6) {\n    result = \"BOYPIL12\"\n} else if (buoyShape == 5 && colour0 == 6) {\n    result = \"BOYSPR12\"\n} else if (buoyShape == 6 && colour0 == 6) {\n    result = \"BOYBAR12\"\n} else if (Includes([9], categoryOfSpecialPurposeMark)) {\n    result = \"BOYSUP01\"\n\n} else if (Includes([15], categoryOfSpecialPurposeMark)) {\n    result = \"BOYSUP03\"\n\n} else if (buoyShape == 1) {\n    result = \"BOYCON01\"\n} else if (buoyShape == 2) {\n    result = \"BOYCAN01\"\n} else if (buoyShape == 3) {\n    result = \"BOYSPH01\"\n} else if (buoyShape == 4) {\n    result = \"BOYPIL01\"\n} else if (buoyShape == 5) {\n    result = \"BOYSPR01\"\n} else if (buoyShape == 6) {\n    result = \"BOYBAR01\"\n} else if (buoyShape == 7) {\n    result = \"BOYSUP01\"\n\n} else if (buoyShape == 8) {\n    result = \"BOYSPR01\"\n\n} else {\n    result = \"BOYGEN03\"\n}\n\nreturn result",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
      "scaleSymbols" : true,
      "snappable" : true
    },
