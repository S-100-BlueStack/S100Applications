        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var json = Dictionary($feature.attributebindings)\n\nvar buoyShape = IIf(HasKey(json, \"buoyShape\"),json[\"buoyShape\"],-1)\nvar colour1 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\nvar colour2 = IIf(HasKey(json, \"colour[1]\"),json[\"colour[1]\"],-1)\n\n\nif ((buoyShape == 3) && ((colour1 == 1 && colour2 == 3) || (colour1 == 3 && colour2 == 1))) {\n    return \"BOYSPH50\";\n} else if ((buoyShape == 4) && ((colour1 == 1 && colour2 == 3) || (colour1 == 3 && colour2 == 1))) {\n    return \"BOYPIL50\";\n} else if ((buoyShape == 5) && ((colour1 == 1 && colour2 == 3) || (colour1 == 3 && colour2 == 1))) {\n    return \"BOYSPR50\";\n} else if (buoyShape == 3) {\n    return \"BOYSPH01\";\n} else if (buoyShape == 4) {\n    return \"BOYPIL01\";\n} else if (buoyShape == 5) {\n    return \"BOYSPR01\";\n} else if (buoyShape == 6) {\n    return \"BOYBAR01\";\n} else if (buoyShape == 7) {\n    // Note: Arcade cannot modify external variables like textOffsetX directly\n    // You could return an object if the environment supports it or handle offset elsewhere\n    return \"BOYSUP01\";\n} else if (buoyShape == 8) {\n    return \"BOYSPR01\";\n} else {\n    return \"BOYGEN03\";\n}",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
