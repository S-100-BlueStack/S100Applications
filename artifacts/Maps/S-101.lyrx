        "useDefaultSymbol" : true,
        "isDefaultSymbolVisible" : true,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var json = Dictionary($feature.attributebindings)\n\nvar shape = IIf(HasKey(json, \"buoyShape\"),json[\"buoyShape\"],-1)\nvar colour0 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\nvar colour1 = IIf(HasKey(json, \"colour[1]\"),json[\"colour[1]\"],-1)\nvar colour2 = IIf(HasKey(json, \"colour[2]\"),json[\"colour[2]\"],-1)\n\nvar c1 = -1;\nif (colour0 > -1) {\n    c1 = colour0;\n}\n\nvar c2 = -1;\nif (colour1 > -1) {\n    c2 = colour1;\n}\n\nvar c3 = -1;\nif (colour2 > -1) {\n    c3 = colour2;\n}\n\n// Specific multi-colour patterns\nif (shape == 1 && c1 == 3 && c2 == 4 && c3 == 3) {\n    return \"BOYCON30\"\n} else if (shape == 2 && c1 == 3 && c2 == 4 && c3 == 3) {\n    return \"BOYCAN30\"\n} else if (shape == 4 && c1 == 3 && c2 == 4 && c3 == 3) {\n    return \"BOYPIL30\"\n} else if (shape == 5 && c1 == 3 && c2 == 4 && c3 == 3) {\n    return \"BOYSPR30\"\n} else if (shape == 1 && c1 == 4 && c2 == 3 && c3 == 4) {\n    return \"BOYCON31\"\n} else if (shape == 2 && c1 == 4 && c2 == 3 && c3 == 4) {\n    return \"BOYCAN31\"\n} else if (shape == 4 && c1 == 4 && c2 == 3 && c3 == 4) {\n    return \"BOYPIL31\"\n} else if (shape == 5 && c1 == 4 && c2 == 3 && c3 == 4) {\n    return \"BOYSPR31\"\n} else if (shape == 1 && c1 == 3) {\n    return \"BOYCON10\"\n} else if (shape == 1 && c1 == 4) {\n    return \"BOYCON11\"\n} else if (shape == 2 && c1 == 3) {\n    return \"BOYCAN10\"\n} else if (shape == 2 && c1 == 4) {\n    return \"BOYCAN11\"\n} else if (shape == 3 && c1 == 3) {\n    return \"BOYSPH10\"\n} else if (shape == 3 && c1 == 4) {\n    return \"BOYSPH11\"\n} else if (shape == 4 && c1 == 3) {\n    return \"BOYPIL10\"\n} else if (shape == 4 && c1 == 4) {\n    return \"BOYPIL11\"\n} else if (shape == 5 && c1 == 3) {\n    return \"BOYSPR10\"\n} else if (shape == 5 && c1 == 4) {\n    return \"BOYSPR11\"\n} else if (shape == 6 && c1 == 3) {\n    return \"BOYBAR10\"\n} else if (shape == 6 && c1 == 4) {\n    return \"BOYBAR11\"\n\n// Fallbacks for shape only\n} else if (shape == 1) {\n    return \"BOYCON01\"\n} else if (shape == 2) {\n    return \"BOYCAN01\"\n} else if (shape == 3) {\n    return \"BOYSPH01\"\n} else if (shape == 4) {\n    return \"BOYPIL01\"\n} else if (shape == 5) {\n    return \"BOYSPR01\"\n} else if (shape == 6) {\n    return \"BOYBAR01\"\n} else if (shape == 7) {\n    return \"BOYSUP01\"\n} else if (shape == 8) {\n    return \"BOYSPR01\"\n} else {\n    return \"BOYGEN03\"\n}\n\nreturn -1\n\n\n",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
