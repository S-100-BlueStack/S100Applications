        "useDefaultSymbol" : true,
        "isDefaultSymbolVisible" : true,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var result = \"BCNGEN03\"\nvar json = Dictionary($feature.attributebindings)\n\nvar beaconShape = IIf(HasKey(json, \"beaconShape\"),json[\"beaconShape\"],-1)\nvar visualProminence = IIf(HasKey(json, \"visualProminence\"),json[\"visualProminence\"],[])\nvar categoryOfSpecialPurposeMark = IIf(HasKey(json, \"categoryOfSpecialPurposeMark\"),json[\"categoryOfSpecialPurposeMark\"],[])\nvar colour0 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\n\nif (beaconShape == 6 && visualProminence == 1) {\n    result = \"CAIRNS11\"\n} else if (Includes([18],categoryOfSpecialPurposeMark)) {\n    result = \"NOTBRD11\"\n} else if (Includes([44], categoryOfSpecialPurposeMark)) {\n    result = \"BCNGEN01\"\n} else if (beaconShape == 3 && colour0 == 2) {\n    result = \"BCNTOW13\"\n} else if (beaconShape == 3 && colour0 == 6) {\n    result = \"BCNTOW12\"\n} else if (beaconShape == 5 && colour0 == 2) {\n    result = \"BCNGEN13\"\n} else if (beaconShape == 5 && colour0 == 6) {\n    result = \"BCNGEN12\"\n} else if (beaconShape == 7 && colour0 == 2) {\n    result = \"BCNGEN13\"\n} else if (beaconShape == 7 && colour0 == 6) {\n    result = \"BCNGEN12\"\n} else if (beaconShape == 1) {\n    result = \"BCNSTK02\"\n} else if (beaconShape == 3) {\n    result = \"BCNTOW01\"\n} else if (beaconShape == 4) {\n    result = \"BCNLTC01\"\n} else if (beaconShape == 5) {\n    result = \"BCNGEN01\"\n} else if (beaconShape == 6) {\n    result = \"CAIRNS01\"\n} else if (beaconShape == 7) {\n    result = \"BCNGEN01\"\n} else {\n    result = \"BCNGEN03\"\n}\n\nreturn result\n",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
