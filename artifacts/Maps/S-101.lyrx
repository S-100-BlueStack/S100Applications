        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "function containsValue(arr, value) {\n    if (IsEmpty(arr)) {\n        return false;\n    }\n    if (TypeOf(arr) == \"Array\") {\n        return IndexOf(arr, value) >= 0;\n    }\n    return arr == value; // handle single value case\n}\n\nvar json = Dictionary($feature.attributebindings)\nvar beaconShape = IIf(HasKey(json, \"beaconShape\"),json[\"beaconShape\"],-1)\nvar natureOfConstruction = IIf(HasKey(json, \"beaconShape\"),json[\"beaconShape\"],-1)\n\nif (beaconShape == 1) {\n   return \"BCNSTK02\";\n} else if (beaconShape == 3) {\n   return \"BCNTOW01\";\n} else if (containsValue(natureOfConstruction, 11)) {\n   return \"BCNLTC01\";\n} else if (beaconShape == 5) {\n   return \"BCNGEN01\";\n} else if (beaconShape == 7) {\n   return \"BCNGEN01\";\n} else {\n    return \"BCNGEN03\";\n}\n\n\n\n",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
