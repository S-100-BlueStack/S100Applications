      "labelClasses" : [
        {
          "type" : "CIMLabelClass",
          "expressionTitle" : "Custom",
          "expression" : "// Function to round depth based on the specified rules and return the number and fraction part as a whole number\nfunction roundDepth(depth) {\n    var intPart = Floor(depth); // Get the integer part\n    var decimalPart = depth - intPart; // Get the decimal part\n\n    if (depth >= 0.1 && depth <= 21) {\n        // Round to nearest decimetre between 0.1m and 21m\n        decimalPart = Floor(decimalPart * 10);  // Convert decimal to whole number (tens place of the decimal)\n        return [intPart, decimalPart];  // Return as list [number, fraction]\n    }\n    else if (depth > 21 && depth <= 31) {\n        // Round to nearest 0.5m between 21m and 31m\n        if (decimalPart < 0.5) {\n            decimalPart = 0;  // Round down to nearest whole meter\n        } else {\n            decimalPart = 5;  // Round to 0.5m\n        }\n        return [intPart, decimalPart];  // Return as list [number, fraction]\n    }\n    else if (depth > 31) {\n        // Round down to nearest meter for depths greater than 31m\n        decimalPart = 0;  // No decimal part for depths > 31\n        return [intPart, decimalPart];  // Return as list [number, fraction]\n    }\n    return [intPart, decimalPart];  // Return the integer and decimal part\n}\n\n// NOT IN USE\n// Function to round drying height and return the number and fraction part as a whole number\nfunction roundDryingHeight(height) {\n    var intPart = Floor(height); // Get the integer part\n    var decimalPart = height - intPart; // Get the decimal part\n\n    // Round up to the nearest decimetre if the decimal part is between 0.001 and 0.099\n    if (decimalPart > 0 && decimalPart < 0.1) {\n        decimalPart = Ceil(decimalPart * 10);  // Convert decimal to whole number (tens place of the decimal)\n    }\n\n    return [intPart, decimalPart];  // Return as list [number, fraction]\n}\n\nvar roundedDepth = roundDepth(Geometry($feature).points[0].Z)\nvar numb = roundedDepth[0]\nvar frac = roundedDepth[1]\nvar label = \"\"\nif (frac > 0)\n{\n   label = roundedDepth[0] + \"<sub>\" + roundedDepth[1] + \"</sub>\";\n} else {\n   label = roundedDepth[0];\n}\nreturn label\n",
          "expressionEngine" : "Arcade",
