      "featureBlendingMode" : "Alpha",
      "layerEffectsMode" : "Layer",
      "labelClasses" : [
        {
          "type" : "CIMLabelClass",
          "expressionTitle" : "Custom",
          "expression" : "function GetColour(COLOUR) {\n    var strCOLOUR = \"\";\n    if (COLOUR == \"white\") {\n        strCOLOUR = \"\";\n    } else if (COLOUR == 2) {\n        strCOLOUR = \"Bl\";\n    } else if (COLOUR == 3) {\n        strCOLOUR = \"R\";\n    } else if (COLOUR == 4) {\n        strCOLOUR = \"G\";\n    } else if (COLOUR == 5) {\n        strCOLOUR = \"Bu\";\n    } else if (COLOUR == 6) {\n        strCOLOUR = \"Y\";\n    } else if (COLOUR == 7) {\n        strCOLOUR = \"Gr\";\n    } else if (COLOUR == 8) {\n        strCOLOUR = \"Br\";\n    } else if (COLOUR == 9) {\n        strCOLOUR = \"Am\";\n    } else if (COLOUR == 10) {\n        strCOLOUR = \"Vi\";\n    } else if (COLOUR == 11) {\n        strCOLOUR = \"Or\";\n    } else if (COLOUR == 12) {\n        strCOLOUR = \"Ma\";\n    } else if (COLOUR == 13) {\n        strCOLOUR = \"Pi\";\n    } else if (IsEmpty(COLOUR)) {\n        strCOLOUR = \"\";\n    } else {\n        strCOLOUR = \"\";\n    }\n    if (strCOLOUR != \"\") {\n        strCOLOUR += \".\";\n    }\n    return strCOLOUR\n}\n\nfunction GetLitChr(LITCHR) {\n    var strLITCHR = \"\"\n    if (LITCHR == 1 || LITCHR == \"fixed\") {\n        strLITCHR = \"F\";\n    } else if (LITCHR == 2 || LITCHR == \"flashing\") {\n        strLITCHR = \"Fl\";\n    } else if (LITCHR == 3 || LITCHR == \"long-flashing\") {\n        strLITCHR = \"LFl\";\n    } else if (LITCHR == 4 || LITCHR == \"quick-flashing\") {\n        strLITCHR = \"Q\";\n    } else if (LITCHR == 5 || LITCHR == \"very quick-flashing\") {\n        strLITCHR = \"VQ\";\n    } else if (LITCHR == 6 || LITCHR == \"continuous ultra quick-flashing\") {\n        strLITCHR = \"UQ\";\n    } else if (LITCHR == 7 || LITCHR == \"isophased\") {\n        strLITCHR = \"Iso\";\n    } else if (LITCHR == 8 || LITCHR == \"occulting\") {\n        strLITCHR = \"Oc\";\n    } else if (LITCHR == 11 || LITCHR == \"interrupted ultra quick-flashing\") {\n        strLITCHR = \"IQ\";\n    } else if (LITCHR == 12 || LITCHR == \"morse\") {\n        strLITCHR = \"Mo\";\n    } else if (LITCHR == 13 || LITCHR == \"fixed/flash\") {\n        strLITCHR = \"FFI\";\n    } else if (LITCHR == 14 || LITCHR == \"flash/long-flash\") {\n        strLITCHR = \"LFI\";\n    } else if (LITCHR == 15 || LITCHR == \"occulting/flash\") {\n        strLITCHR = \"OcFl\";\n    } else if (LITCHR == 16 || LITCHR == \"fixed/long-flash\") {\n        strLITCHR = \"FLFI\";\n    } else if (LITCHR == 17 || LITCHR == \"occulting alternating\") {\n        strLITCHR = \"OcAI.WR\";\n    } else if (LITCHR == 18 || LITCHR == \"long-flash alternating\") {\n        strLITCHR = \"LFIAI.WR\";\n    } else if (LITCHR == 19 || LITCHR == \"flash alternating\") {\n        strLITCHR = \"FLAI.WR\";\n    } else if (LITCHR == \"group alternating\") {\n        strLITCHR = \"AI.WR\";\n    } else if (LITCHR == 25 || LITCHR == \"quick-flash plus long-flash\") {\n        strLITCHR = \"LQ\";\n    } else if (LITCHR == 26 || LITCHR == \"very quick-flash plus long-flash\") {\n        strLITCHR = \"LVQ\";\n    } else if (LITCHR == 27 || LITCHR == \"ultra quick-flash plus long-flash\") {\n        strLITCHR = \"LUQ\";\n    } else if (LITCHR == 28 || LITCHR == \"alternating\") {\n        strLITCHR = \"AI.WR\";\n    } else if (LITCHR == 29 || LITCHR == \"fixed and alternating flashing\") {\n        strLITCHR = \"FAL.WR\";\n    } else if (IsEmpty(LITCHR)) {\n        strLITCHR = \"\";\n    } else {\n        strLITCHR = \"\";\n    }\n\n    return strLITCHR\n}\n\n\n\nfunction IsNumeric(val) {\n    return !(IsEmpty(Number(val)) || Number(val) == null);\n}\nvar json = Dictionary($feature.attributebindings)\n\nvar results = [];\n\nvar multi = \"null\";\n\nvar multiplicityOfFeatures = IIf(HasKey(json, \"multiplicityOfFeatures\"),json[\"multiplicityOfFeatures\"],-1)\n\nif (multiplicityOfFeatures != -1) {\n    multi = multiplicityOfFeatures;\n}\n\nvar catLight = \"[]\";\nvar categoryOfLight = IIf(HasKey(json, \"categoryOfLight\"),json[\"categoryOfLight\"],-1)\n\nif (categoryOfLight != -1) {\n    catLight = categoryOfLight;\n}\n\nvar height = \"\"\nvar heightValue = json[\"height\"];\nif (IsNumeric(heightValue) && heightValue > 0) {\n    height = Text(heightValue, \"#.#\") + \"m\";\n} else {\n    height = \"\";\n}\n\nvar sectorCharacteristics = []\nvar i = 0;\nvar SIGGRP = \"\"\nvar countSectorCharacteristics = \"\"\nwhile (HasKey(json, \"sectorCharacteristics[\" + i + \"].lightCharacteristic\")) {\n    countSectorCharacteristics += 1;\n    \n    var litchr = GetLitChr(json[\"sectorCharacteristics[\" + i + \"].lightCharacteristic\"])\n    var signalGroup = json[\"sectorCharacteristics[\" + i + \"].signalGroup[0]\"]\n    var colourValue = \"\"\n    var colour = \"\"\n    var colourValue = json[\"sectorCharacteristics[\" + i + \"].lightSector[0].colour[0]\"]\n    if (IsNumeric(colourValue) && colourValue > 1) {\n        colour = GetColour(colourValue);\n    } else {\n        colour = \"\";\n    }\n\n    var signalPeriod = \"\"\n    var signalPeriodValue = json[\"sectorCharacteristics[\" + i + \"].signalPeriod\"]\n    if (IsNumeric(signalPeriodValue) && signalPeriodValue > 0) {\n        // Replace '.' with ',' for decimals in Arcade\n        signalPeriod = Text(signalPeriodValue, \"#.##\");\n        signalPeriod = Replace(signalPeriod, \".\", \",\") + \"s\";\n    } else {\n        signalPeriod = \"\";\n    }    \n    var range = \"\"\n    var rangeValue = json[\"sectorCharacteristics[\" + i + \"].lightSector[0].valueOfNominalRange\"]\n    if (IsNumeric(rangeValue) && rangeValue > 1) {\n        range = Text(rangeValue, \"#\") + \"M\";\n    } else {\n        range = \"\";\n    }\n\n    var s = /* multi + catLight + */litchr + signalGroup + colour  + signalPeriod + height + range;\n    \n    Push(results, s);    \n    i += 1;\n}\nreturn Concatenate(results, TextFormatting.NewLine);\n",
          "expressionEngine" : "Arcade",
