        "isDefaultSymbolVisible" : false,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var json = Dictionary($feature.attributebindings)\n\nvar c1 = IIf(HasKey(json, \"sectorCharacteristics[0].lightSector[0].colour[0]\"),json[\"sectorCharacteristics[0].lightSector[0].colour[0]\"],-1)\nvar c2 = IIf(HasKey(json, \"sectorCharacteristics[0].lightSector[0].colour[1]\"),json[\"sectorCharacteristics[0].lightSector[0].colour[0]\"],-1)\n\nif (c1 == -1) {\n    return\n}\n\nvar sectorColourToken = \"\";\nvar sectorLightSymbol = \"\";\n\nif (c1 == 1 && c2 == 3) {\n    // white and red\n    sectorLightSymbol = \"LIGHTS11\";\n} else if (c1 == 3) {\n    // red\n    sectorLightSymbol = \"LIGHTS11\";\n} else if (c1 == 1 && c2 == 4) {\n    // white and green\n    sectorLightSymbol = \"LIGHTS12\";\n} else if (c1 == 4) {\n    // green\n    sectorLightSymbol = \"LIGHTS12\";\n} else if (c1 == 11 || c1 == 6 || c1 == 1) {\n    // orange or yellow or white\n    sectorLightSymbol = \"LIGHTS13\";\n} else if (c1 == 1 && c2 == 6) {\n    // blue and yellow\n    sectorLightSymbol = \"LIGHTS13\";\n} else {\n    sectorLightSymbol = \"LITDEF11\";\n}\n\nreturn sectorLightSymbol\n",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
      "scaleSymbols" : true,
      "snappable" : true
    },
