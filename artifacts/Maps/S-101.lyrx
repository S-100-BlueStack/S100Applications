          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "var json = Dictionary($feature.attributebindings)\n\nvar c1 = IIf(HasKey(json, \"colour[0]\"),json[\"colour[0]\"],-1)\nvar c2 = IIf(HasKey(json, \"colour[1]\"),json[\"colour[1]\"],-1)\n\nif (c1 == -1) {\n    return\n}\n\nvar sectorColourToken = \"\";\nvar sectorLightSymbol = \"\";\n\nif (c1 == 1 && c2 == 3) {\n    // white and red\n    sectorColourToken = \"LITRD\";\n    sectorLightSymbol = \"LIGHTS11\";\n} else if (c1 == 3) {\n    // red\n    sectorColourToken = \"LITRD\";\n    sectorLightSymbol = \"LIGHTS11\";\n} else if (c1 == 1 && c2 == 4) {\n    // white and green\n    sectorColourToken = \"LITGN\";\n    sectorLightSymbol = \"LIGHTS12\";\n} else if (c1 == 4) {\n    // green\n    sectorColourToken = \"LITGN\";\n    sectorLightSymbol = \"LIGHTS12\";\n} else if (c1 == 11 || c1 == 6 || c1 == 1) {\n    // orange or yellow or white\n    sectorColourToken = \"LITYW\";\n    sectorLightSymbol = \"LIGHTS13\";\n} else if (c1 == 1 && c2 == 6) {\n    // blue and yellow\n    sectorColourToken = \"LITYW\";\n    sectorLightSymbol = \"LIGHTS13\";\n} else {\n    sectorColourToken = \"CHMGD\";\n    sectorLightSymbol = \"LITDEF11\";\n}\n\nreturn sectorLightSymbol\n\n\n\n/*\nreturn {\n    sectorColourToken: sectorColourToken,\n    sectorLightSymbol: sectorLightSymbol\n}\n*/\n",
          "returnType" : "Default"
