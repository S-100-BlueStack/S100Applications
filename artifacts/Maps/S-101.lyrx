        "isDefaultSymbolVisible" : false,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "S-101",
          "expression" : "var json = Dictionary($feature.attributebindings)\nvar topmarkDayShape = IIf(HasKey(json, \"topmark.topmarkDaymarkShape\"),json[\"topmark.topmarkDaymarkShape\"],-1)\n\nvar rigidTopmarks =\n{\n    '1':'TOPMAR22',\n    '2':'TOPMAR24',\n    '3':'TOPMAR30',\n    '4':'TOPMAR32',\n    '5':'TOPMAR33',\n    '6':'TOPMAR34',\n    '7':'TOPMAR85',\n    '8':'TOPMAR86',\n    '9':'TOPMAR36',\n    '10':'TOPMAR28',\n    '11':'TOPMAR27',\n    '12':'TOPMAR14',\n    '13':'TOPMAR25',\n    '14':'TOPMAR26',\n    '15':'TOPMAR88',\n    '16':'TOPMAR87',\n    '17':'TMARDEF1',\n    '18':'TOPMAR30',\n    '19':'TOPMAR33',\n    '20':'TOPMAR34',\n    '21':'TOPMAR33',\n    '22':'TOPMAR34',\n    '23':'TOPMAR34',\n    '24':'TOPMAR22',\n    '25':'TOPMAR24',\n    '26':'TOPMAR30',\n    '27':'TOPMAR86',\n    '28':'TOPMAR89',\n    '29':'TOPMAR22',\n    '30':'TOPMAR86',\n    '31':'TOPMAR14',\n    '32':'TOPMAR30',\n    '33':'TMARDEF1'\n}\n\nif (topmarkDayShape == -1) {\n  return\n}\n\nreturn rigidTopmarks[topmarkDayShape+'']",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
      "scaleSymbols" : true,
      "snappable" : true
