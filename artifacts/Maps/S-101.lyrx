        "useDefaultSymbol" : true,
        "isDefaultSymbolVisible" : true,
        "valueExpressionInfo" : {
          "type" : "CIMExpressionInfo",
          "title" : "Custom",
          "expression" : "// Arcade expression to choose the point instruction code for a lateral beacon\nvar dict = Dictionary($feature.attributebindings)\n\n// Get feature attributes (simulate feature.colour as array [r,g,b])\nvar beaconShape = IIf(HasKey(dict, \"beaconShape\"),dict[\"beaconShape\"],-1)\nvar visualProminence = IIf(HasKey(dict, \"visualProminence\"),dict[\"visualProminence\"],[])\nvar categoryOfLateralMark = IIf(HasKey(dict, \"categoryOfLateralMark\"),dict[\"categoryOfLateralMark\"],[])\nvar colour0 = IIf(HasKey(dict, \"colour[0]\"),dict[\"colour[0]\"],-1)\nvar colour1 = IIf(HasKey(dict, \"colour[1]\"),dict[\"colour[1]\"],-1)\nvar colour2 = IIf(HasKey(dict, \"colour[2]\"),dict[\"colour[2]\"],-1)\n\nvar colour = [colour0,colour1,colour2]\n\n// Helper function to compare color arrays\nfunction colorEquals(c1, c2) {\n    return (Count(c1) == Count(c2)) &&\n           (c1[0] == c2[0]) &&\n           (c1[1] == c2[1]) &&\n           (c1[2] == c2[2])\n}\n\n// Set up some color constants\nvar greenRedGreen = [4,3,4]\nvar redGreenRed = [3,4,3]\n\n// Non-simplified symbols logic\nif (beaconShape == 3 && colorEquals(colour, redGreenRed)) {\n    return \"BCNTOW30\"\n} else if ((beaconShape == 5 || beaconShape == 7) && colorEquals(colour, redGreenRed)) {\n    return \"BCNGEN30\"\n} else if (beaconShape == 3 && colorEquals(colour, greenRedGreen)) {\n    return \"BCNTOW31\"\n} else if ((beaconShape == 5 || beaconShape == 7) && colorEquals(colour, greenRedGreen)) {\n    return \"BCNGEN31\"\n} else if (beaconShape == 3 && colour0 == 3) {\n    return \"BCNTOW10\"\n} else if ((beaconShape == 5 || beaconShape == 7) && colour0 == 3) {\n    return \"BCNGEN10\"\n} else if (beaconShape == 3 && colour0 == 4) {\n    return \"BCNTOW11\"\n} else if ((beaconShape == 5 || beaconShape == 7) && colour0 == 4) {\n    return \"BCNGEN11\"\n} else if (beaconShape == 2 && categoryOfLateralMark == 1) {\n    return \"PRICKE03\"\n} else if (beaconShape == 2 && categoryOfLateralMark == 2) {\n    return \"PRICKE04\"\n} else if (beaconShape == 6 && visualProminence == 1) {\n    return \"CAIRNS11\"\n} else if (beaconShape == 1) {\n    return \"BCNSTK02\"\n} else if (beaconShape == 3) {\n    return \"BCNTOW01\"\n} else if (beaconShape == 4) {\n    return \"BCNLTC01\"\n} else if (beaconShape == 5) {\n    return \"BCNGEN01\"\n} else if (beaconShape == 6) {\n    return \"CAIRNS01\"\n} else if (beaconShape == 7) {\n    return \"BCNGEN01\"\n} else {\n    return \"BCNGEN03\"\n}\n",
          "returnType" : "Default"
        },
        "polygonSymbolColorTarget" : "Fill"
      },
      "scaleSymbols" : true,
      "snappable" : true
    },
